<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0b0f14"
    android:padding="32dp">

    <TextView
        android:id="@+id/greeting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hi! 👋"
        android:textColor="#19c37d"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Continue Watching rail (populated in code from the Resume store; hidden when empty). -->
    <LinearLayout
        android:id="@+id/cwSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/cwLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶  Keep watching"
            android:textColor="#e6edf3"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="4dp"
            android:layout_marginBottom="10dp" />

        <HorizontalScrollView
            android:id="@+id/cwScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/cwRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>
    </LinearLayout>

    <Button
        android:id="@+id/liveBtn"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="📺  Watch Live TV"
        android:textSize="20sp"
        android:padding="18dp" />

    <Button
        android:id="@+id/moviesBtn"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="🎬  Movies &amp; Shows"
        android:textSize="20sp"
        android:padding="18dp" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="#8b97a5"
        android:textSize="15sp"
        android:text="" />
</LinearLayout>
