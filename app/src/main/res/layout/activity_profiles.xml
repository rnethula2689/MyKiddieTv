<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0b0f14"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MyKiddieTv"
        android:textColor="#19c37d"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="36dp"
        android:text="Who's watching?"
        android:textColor="#8b97a5"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/parentTile"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginEnd="28dp"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/parentName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Parent"
                android:textColor="#e6edf3"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 passcode"
                android:textColor="#8b97a5"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/kidTile"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:gravity="center"
            android:focusable="true"
            android:clickable="true"
            android:background="@drawable/item_bg">

            <TextView
                android:id="@+id/kidAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:gravity="center"
                android:text="🧸"
                android:textColor="#ffffff"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/kidName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Kids"
                android:textColor="#e6edf3"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="tap to watch"
                android:textColor="#8b97a5"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
