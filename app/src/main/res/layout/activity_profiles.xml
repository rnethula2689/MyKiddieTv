<?xml version="1.0" encoding="utf-8"?>
<!-- ScrollView so a short landscape viewport never clips the kids row; fillViewport keeps it
     vertically centred when the content is shorter than the screen. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0b0f14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MyKiddieTv"
            android:textColor="#19c37d"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="14dp"
            android:text="Who's watching?"
            android:textColor="#8b97a5"
            android:textSize="16sp" />

        <!-- Top of the tree: the Parent tile -->
        <LinearLayout
            android:id="@+id/parentRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal" />

        <!-- Connector down to the kids -->
        <View
            android:layout_width="2dp"
            android:layout_height="16dp"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:background="#33ffffff" />

        <!-- The kids branch (+ Add kid) flows into rows sized to fit the current width, so tiles
             (especially "Add kid") wrap onto the next visible row instead of hiding off-screen.
             The outer ScrollView handles overflow when there are many kids. -->
        <LinearLayout
            android:id="@+id/tileGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
